{
  "name": "toolify-ai-autonomous-engine",
  "version": "2.4.0",
  "description": "Toolify AI — Fully autonomous company engine. Image generation + email approval.",
  "main": "server.js",
  "scripts": {
    "start":        "node server.js",
    "dev":          "nodemon server.js",
    "test-tokens":  "node test-tokens.js",
    "post-now":     "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(()=>o.immediatePost()).then(r=>{if(r&&r.skipped){console.log('Already posted today. Use npm run force-post to override.')}setTimeout(()=>process.exit(0),15000)})\"",
    "force-post":   "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(()=>o.forcePost()).then(()=>setTimeout(()=>process.exit(0),15000))\"",
    "test-daily":   "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(()=>o.forcePost()).then(()=>setTimeout(()=>process.exit(0),30000))\"",
    "test-linkedin":"node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(async()=>{const c=await o.agents.content.generateDailyContent({});console.log('LinkedIn text:');console.log(c.linkedin?.text||c.linkedin);const r=await o.agents.publisher.postToLinkedIn(c.linkedin);console.log('Result:',r);process.exit(0)})\"",
    "test-twitter": "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(async()=>{const c=await o.agents.content.generateDailyContent({});console.log('Tweets:',c.twitter);const r=await o.agents.publisher.postTwitterThread(c.twitter);console.log('Result:',r);process.exit(0)})\"",
    "get-linkedin": "node linkedin-auth.js",
    "pm2-start":    "pm2 start ecosystem.config.js",
    "pm2-logs":     "pm2 logs nicheai-engine",
    "pm2-restart":  "pm2 restart nicheai-engine"
  },
  "dependencies": {
    "axios":              "^1.6.5",
    "cheerio":            "^1.0.0-rc.12",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "mongoose":           "^8.1.1",
    "node-cron":          "^3.0.3",
    "razorpay":           "^2.9.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
