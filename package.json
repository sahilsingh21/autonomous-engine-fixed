{
  "name": "toolify-ai-autonomous-engine",
  "version": "2.1.0",
  "description": "Toolify AI — Fully autonomous company engine",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "post-now": "node -e \"require('dotenv').config(); const o=require('./orchestrator'); o.initialize().then(()=>o.immediatePost()).then(()=>setTimeout(()=>process.exit(0),15000))\"",
    "test-daily": "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(()=>o.dailyLoop()).then(()=>setTimeout(()=>process.exit(0),30000))\"",
    "test-research": "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(()=>o.triggerManual('research','trendResearch')).then(r=>{console.log(JSON.stringify(r,null,2));process.exit(0)})\"",
    "test-linkedin": "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(async()=>{const c=await o.agents.content.generateDailyContent({});const r=await o.agents.publisher.postToLinkedIn(c.linkedin);console.log(r);process.exit(0)})\"",
    "test-twitter": "node -e \"require('dotenv').config();const o=require('./orchestrator');o.initialize().then(async()=>{const c=await o.agents.content.generateDailyContent({});const r=await o.agents.publisher.postTwitterThread(c.twitter);console.log(r);process.exit(0)})\"",
    "get-linkedin": "node linkedin-auth.js",
    "pm2-start": "pm2 start ecosystem.config.js",
    "pm2-logs": "pm2 logs nicheai-engine",
    "test-tokens": "node test-tokens.js"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "mongoose": "^8.1.1",
    "node-cron": "^3.0.3",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}