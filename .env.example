# ════════════════════════════════════════
# NICHEAI AUTONOMOUS ENGINE — CONFIGURATION
# ════════════════════════════════════════
# Copy to .env and fill in your keys
# Start with just MONGODB_URI + ANTHROPIC_API_KEY
# Add social keys one by one as you scale

# ── SERVER
ENGINE_PORT=4000
AUTOSTART=true

# ── DATABASE (required)
MONGODB_URI=mongodb://localhost:27017/nicheai-engine

# ── AI PROVIDER (required — pick one or both)
AI_PROVIDER=anthropic          # anthropic | ollama

# Anthropic API (cloud, pay per token)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (local, free — run: ollama pull llama3.2)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── PAYMENTS (required for revenue tracking)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── BUDGET CONTROLS
DAILY_API_BUDGET=50            # Max $ to spend on AI API per day
MONTHLY_BUDGET=100             # Hard cap on total monthly spend
MIN_MARGIN=0.30                # Kill product if margin drops below 30%
AD_BUDGET_DAILY=5              # Max $ per day on paid ads

# ── PRODUCT URLS (your live product landing pages)
REPLYDRAFT_URL=https://replydraft.nicheailabs.com
LISTINGLIFT_URL=https://listinglift.nicheailabs.com
POLICYPAL_URL=https://policypal.nicheailabs.com

# ════════════════════════════════════════
# SOCIAL MEDIA — PUBLISHING
# Add these to enable real autonomous posting
# ════════════════════════════════════════

# REDDIT (free — create app at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-app-id
REDDIT_CLIENT_SECRET=your-reddit-app-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
# Without these: posts are simulated and logged but not published

# TWITTER / X (apply at developer.twitter.com)
# Requires Elevated access for posting
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# LINKEDIN (apply at linkedin.com/developers)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_ID=your-linkedin-person-id
# Refresh token (LinkedIn tokens expire every 60 days)
LINKEDIN_REFRESH_TOKEN=your-refresh-token

# ════════════════════════════════════════
# ADVERTISING
# ════════════════════════════════════════

# REDDIT ADS (ads.reddit.com → API access)
REDDIT_ADS_ACCESS_TOKEN=your-reddit-ads-token
REDDIT_ADS_ACCOUNT_ID=your-account-id

# GOOGLE ADS (optional, for search ads)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token

# ════════════════════════════════════════
# RESEARCH & ANALYTICS
# ════════════════════════════════════════

# SERPAPI (google trends + search data — serpapi.com)
SERPAPI_KEY=your-serpapi-key
# Without this: research still works using Reddit + HN

# POSTHOG (conversion analytics — posthog.com, free tier)
POSTHOG_API_KEY=your-posthog-key
POSTHOG_PROJECT_ID=your-project-id

# ════════════════════════════════════════
# EMAIL (for revenue alerts — resend.com, free tier)
# ════════════════════════════════════════
RESEND_API_KEY=re_your-resend-key
ALERT_EMAIL=you@yourdomain.com
